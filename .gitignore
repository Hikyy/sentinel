*.log
*.log.*
logs/
spring-boot.log
**/src/main/resources/application-local.yml
**/src/main/resources/application-secret.yml

# === Node / Angular ===
node_modules/
dist/
.angular/
coverage/
.nyc_output/
playwright-report/
test-results/
